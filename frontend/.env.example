# Copy this file to .env.local and adjust as needed.
# .env.local is gitignored — never commit real values.

# Base URL of the backend API (see ../backend). No trailing slash.
# Required — the app throws at startup if this is missing.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Must be the EXACT same value as backend/.env's JWT_SECRET -- proxy.ts
# verifies user session JWTs locally (via `jose`) without calling the
# backend, so the two sides have to share this secret.
JWT_SECRET=replace-with-a-random-32-character-or-longer-secret
