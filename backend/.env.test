# Used automatically when NODE_ENV=test (see src/config/index.ts) --
# committed on purpose, unlike .env: every value here is a dummy,
# test-only placeholder, never a real credential, so there's nothing to
# keep secret. Do not point this at the same database as .env's
# DATABASE_URL -- see "isolated test database" in README.md for why.

NODE_ENV=test
PORT=3000

# A separate database on the same local Postgres instance as .env's
# DATABASE_URL (same host/port/credentials, different database name) --
# set up once via `npm run db:test:setup` (see scripts/setup-test-db.ts).
# Never the same database development data lives in.
DATABASE_URL=postgres://user:password@localhost:5433/aina_plant_test

JWT_SECRET=test-only-jwt-secret-never-used-outside-automated-tests
AI_API_KEY=test-only-ai-api-key-never-used-outside-automated-tests

# Matches .env.example's default -- deliberately NOT silenced: several
# tests (logger.test.ts, request-id.test.ts) assert on actual captured
# log output, which a quieter level would break.
LOG_LEVEL=info
