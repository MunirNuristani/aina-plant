# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# Environment the app is running in. Controls things like logging verbosity
# and error detail. One of: development | test | production
# Optional — defaults to "development".
NODE_ENV=development

# Port the HTTP server listens on.
# Optional — defaults to 3000.
PORT=3000

# Connection string for the primary database (e.g. Postgres).
# Required — the app will not start without it.
# Example: postgres://user:password@localhost:5432/aina_plant
DATABASE_URL=postgres://user:password@localhost:5432/aina_plant

# Secret used to sign and verify JWTs / session tokens.
# Required — must be at least 32 characters. Generate with:
#   openssl rand -base64 32
JWT_SECRET=replace-with-a-random-32-character-or-longer-secret

# API key for the AI recommendation provider.
# Required — the app will not start without it.
AI_API_KEY=replace-with-your-ai-provider-api-key
