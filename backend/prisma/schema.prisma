// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A human account. Every Plant and Device is owned by exactly one User --
// devices get their own userId (not just inherited via Plant) because
// Device.plantId is nullable: an unassigned device would otherwise have no
// derivable owner. SensorReading/CareEvent/Calibration deliberately do NOT
// get their own userId -- every service function that touches them already
// looks up the parent Plant/Device first, so ownership stays derived
// through that existing lookup rather than being duplicated.
model User {
  id           String   @id @default(uuid())
  // Always stored lowercase-normalized by the application layer -- Postgres
  // unique constraints are case-sensitive by default, and this project has
  // no reason to reach for citext.
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plants  Plant[]
  devices Device[]
}

model Plant {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  commonName     String?
  scientificName String?
  location       String?
  notes          String?
  potSize        String?
  soilType       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  devices    Device[]
  readings   SensorReading[]
  careEvents CareEvent[]

  @@index([userId])
}

model Device {
  id                       String    @id @default(uuid())
  name                     String    @db.VarChar(100)
  identifier               String    @unique
  credentialHash           String
  enabled                  Boolean   @default(true)
  reportingIntervalSeconds Int       @default(900)
  firmwareVersion          String?
  lastSeenAt               DateTime?
  createdAt                DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  plantId String?
  plant   Plant?  @relation(fields: [plantId], references: [id])

  readings     SensorReading[]
  calibrations Calibration[]

  @@index([plantId])
  @@index([userId])
}

model SensorReading {
  id String @id @default(uuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id])

  // When the device took the measurement, vs. when the server ingested it.
  // Explicit timestamptz (not the Postgres default of timestamp-without-tz)
  // so both are unambiguously UTC at the storage layer, not just by ORM convention.
  recordedAt DateTime @db.Timestamptz(3)
  receivedAt DateTime @default(now()) @db.Timestamptz(3)

  // Uncalibrated sensor output, stored as reported — never transformed.
  rawMoisture Int

  // Calibrated reading; constrained to [0, 100] via a CHECK constraint added
  // by hand to the migration (Prisma's schema DSL has no @@check support yet).
  moisturePercent Float

  firmwareVersion String?
  wifiRssi        Int?

  @@index([plantId, recordedAt])
  @@index([deviceId])
}

// A device's calibration reference points (raw ADC value when fully dry vs.
// fully wet), used to convert rawMoisture into moisturePercent. Rows are
// never updated in place — recalibrating inserts a new row so historical
// readings can still be interpreted using whichever calibration was
// actually in effect at the time they were recorded.
model Calibration {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  dryValue Int
  wetValue Int

  effectiveAt DateTime @default(now()) @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  @@index([deviceId, effectiveAt])
}

// A fixed vocabulary of manual care actions a user can log against a
// plant. Only WATERING exists for now (the only type this ticket asks
// for) -- a Postgres enum, not a free-text field, since this genuinely is
// a closed set the application controls, not open-ended user text (unlike
// e.g. CareEvent.unit below). Adding a new type later is a plain
// `ALTER TYPE ... ADD VALUE` migration, not a rewrite.
enum CareEventType {
  WATERING
}

// A manually logged care action (currently just watering), kept so it can
// be compared against a plant's SensorReading moisture history -- e.g.
// "did watering actually raise soil moisture, and by how much."
model CareEvent {
  id   String        @id @default(uuid())
  type CareEventType

  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id])

  // When the care action actually happened (the user may log it after
  // the fact, or backdate it) -- distinct from createdAt (when this row
  // was inserted), mirroring SensorReading's recordedAt/receivedAt
  // split. Comparisons against moisture history must use occurredAt, not
  // createdAt.
  occurredAt DateTime @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  // How much was used (e.g. 250) and in what unit (e.g. "ml", "oz",
  // "cups") -- both optional, and free text for unit rather than an enum
  // (unlike CareEventType above): there's no fixed, closed set of
  // watering units worth enforcing at the schema level. amount >= 0 is
  // enforced by a hand-added CHECK constraint (see the migration) --
  // mirrors SensorReading.moisturePercent's existing DB-level range
  // check, and backs the application-level (zod) validation a future
  // care-event-creation endpoint ticket adds.
  amount Float?
  unit   String?
  notes  String?

  // Soft delete: a non-null deletedAt hides this event from normal reads
  // while preserving the row itself -- care events feed into historical
  // moisture comparisons, so actually deleting one would silently rewrite
  // that history. Prisma has no declarative "always exclude soft-deleted
  // rows" mechanism, so every read query against this model must
  // explicitly filter `deletedAt: null`; this comment is that discipline
  // documented at the source, for whoever writes those queries next.
  deletedAt DateTime? @db.Timestamptz(3)

  @@index([plantId, occurredAt])
}
