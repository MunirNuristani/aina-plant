// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Plant {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  commonName     String?
  scientificName String?
  location       String?
  notes          String?
  potSize        String?
  soilType       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  devices  Device[]
  readings SensorReading[]
}

model Device {
  id                       String    @id @default(uuid())
  name                     String    @db.VarChar(100)
  identifier               String    @unique
  credentialHash           String
  enabled                  Boolean   @default(true)
  reportingIntervalSeconds Int       @default(900)
  firmwareVersion          String?
  lastSeenAt               DateTime?
  createdAt                DateTime  @default(now())

  plantId String?
  plant   Plant?  @relation(fields: [plantId], references: [id])

  readings SensorReading[]

  @@index([plantId])
}

model SensorReading {
  id String @id @default(uuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id])

  // When the device took the measurement, vs. when the server ingested it.
  // Explicit timestamptz (not the Postgres default of timestamp-without-tz)
  // so both are unambiguously UTC at the storage layer, not just by ORM convention.
  recordedAt DateTime @db.Timestamptz(3)
  receivedAt DateTime @default(now()) @db.Timestamptz(3)

  // Uncalibrated sensor output, stored as reported — never transformed.
  rawMoisture Int

  // Calibrated reading; constrained to [0, 100] via a CHECK constraint added
  // by hand to the migration (Prisma's schema DSL has no @@check support yet).
  moisturePercent Float

  firmwareVersion String?
  wifiRssi        Int?

  @@index([plantId, recordedAt])
  @@index([deviceId])
}
